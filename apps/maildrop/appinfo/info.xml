<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
	<id>maildrop</id>
	<name>MailDrop</name>
	<summary>Fetches emails with attachments and stores them in Nextcloud</summary>
	<description><![CDATA[
MailDrop fetches emails via IMAP, extracts attachments, and stores them
automatically in a configurable Nextcloud folder.

Configurable in Administration settings:
- Multiple mapping configurations (IMAP → target folder)
- Subject/sender filters
- Fetch interval and behaviour
	]]></description>
	<version>1.1.2</version>
	<licence>MIT</licence>
	<author mail="davejs92@gmail.com">David Schilling</author>
	<namespace>MailDrop</namespace>
	<category>files</category>
	<category>organization</category>
	<website>https://github.com/djschilling/Nextcloud-MailDrop</website>
	<bugs>https://github.com/djschilling/Nextcloud-MailDrop/issues</bugs>
	<repository type="git">https://github.com/djschilling/Nextcloud-MailDrop.git</repository>
	<dependencies>
		<php min-version="8.1" max-version="8.5"/>
		<nextcloud min-version="28" max-version="34"/>
	</dependencies>
	<background-jobs>
		<job>OCA\MailDrop\BackgroundJob\FetchMailJob</job>
	</background-jobs>
	<commands>
		<command>OCA\MailDrop\Command\FetchCommand</command>
	</commands>
	<settings>
		<admin>OCA\MailDrop\Settings\AdminSettings</admin>
		<admin-section>OCA\MailDrop\Settings\AdminSection</admin-section>
	</settings>
</info>
